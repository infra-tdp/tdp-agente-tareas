# =============================================================================
#  TDP Agente de tareas — variables de entorno. En COOLIFY van como
#  Environment/Shared Variables del recurso — este fichero es solo REFERENCIA.
#  Secretos NUNCA en el repo. Toda la administración funcional (chats
#  monitorizados, personas, modo, instrucciones…) se hace desde TDP Gestión.
# =============================================================================

PORT=3100

# BD propia del agente: crea en la PostgreSQL gestionada de UpCloud el usuario
# 'tdp_agente' y la BD 'tdp_agente' (owner tdp_agente). Mismo criterio TLS que
# tdp-gestion-app: DATABASE_CA_CERT con la CA del panel (recomendado) o
# sslmode=no-verify como escape rápido.
DATABASE_URL=postgres://tdp_agente:PASS@HOST.upclouddatabases.com:11569/tdp_agente?sslmode=require
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Solo para desarrollo local con el Postgres del compose
# (docker compose --profile local-db up):
POSTGRES_USER=tdp
POSTGRES_PASSWORD=
POSTGRES_DB=tdp_agente

# --- Evolution API (recurso propio en Coolify, imagen oficial) ---
# La instancia se crea y escanea (QR) desde el manager de Evolution. Después,
# configurar su webhook: url https://<dominio-del-agente>/webhook/evolution,
# evento MESSAGES_UPSERT y header x-agent-token = AGENT_WEBHOOK_TOKEN.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=tdp-tareas

# Tokens propios del agente (genera cada uno con: openssl rand -hex 24)
AGENT_WEBHOOK_TOKEN=
# El MISMO valor va en TDP Gestión como TASK_AGENT_TOKEN:
AGENT_ADMIN_TOKEN=

# --- IA ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_MEDIA_MODEL=claude-haiku-4-5-20251001

# Transcripción de notas de voz y audio de vídeos: cualquier API compatible con
# OpenAI (/audio/transcriptions). Sin STT_API_KEY el agente funciona igual pero
# las notas de voz quedan como "[nota de voz sin transcribir]".
# STT_API_URL=https://api.openai.com/v1
STT_API_KEY=
# STT_MODEL=whisper-1

# --- Gestor de tareas (Jira Cloud) ---
TASK_PROVIDER=jira
JIRA_BASE_URL=https://tallerdelpatinete.atlassian.net
JIRA_EMAIL=
# API token de Atlassian (id.atlassian.com → Security → API tokens)
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=TDP
JIRA_ISSUE_TYPE=Task

# --- Opcional: notificar cada acción del agente a un flujo de N8N (fase 4) ---
N8N_EVENTS_WEBHOOK_URL=
