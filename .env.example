# =============================================================================
#  TDP Agente de tareas — variables de entorno.
#
#  COOLIFY ES EFÍMERO: las variables NO se configuran en su UI. Viven como
#  Secrets/Variables del repo en GitHub y el workflow
#  .github/workflows/deploy.yml las sincroniza al recurso de Coolify por API
#  (ver docs/despliegue.md). Este fichero es la REFERENCIA de nombres y también
#  sirve como .env para desarrollo local. Secretos NUNCA en el repo.
#
#  Convención en GitHub:  valores sensibles → Secrets · resto → Variables.
# =============================================================================

# ─── Secrets de GitHub para el DESPLIEGUE (solo los usa el workflow) ─────────
# URL PÚBLICA del panel de Coolify (alcanzable desde los runners de GitHub;
# la misma que usa la GitHub App de Coolify para sus webhooks), sin /api/v1.
COOLIFY_API_URL=
COOLIFY_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
# GitHub App configurada en Coolify (Sources) con acceso a este repo
COOLIFY_GITHUB_APP_UUID=
# Variables (no secrets): COOLIFY_ENVIRONMENT_NAME (default production),
# COOLIFY_APP_UUID (lo guarda el bootstrap), DEPLOY_BRANCH (default main).

# ─── Runtime del agente ──────────────────────────────────────────────────────
PORT=3100

# BD del agente: usuario 'tdp_agente' y BD 'tdp_agente' en la PostgreSQL
# gestionada de UpCloud. Mismo criterio TLS que tdp-gestion-app:
# DATABASE_CA_CERT con la CA del panel (recomendado) o sslmode=no-verify.
DATABASE_URL=postgres://tdp_agente:PASS@HOST.upclouddatabases.com:11569/tdp_agente?sslmode=require
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Tokens propios del agente (genera cada uno con: openssl rand -hex 24)
AGENT_WEBHOOK_TOKEN=
# El MISMO valor va en TDP Gestión como TASK_AGENT_TOKEN:
AGENT_ADMIN_TOKEN=

# --- IA ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_MEDIA_MODEL=claude-haiku-4-5-20251001

# Transcripción de notas de voz y audio de vídeos: cualquier API compatible con
# OpenAI (/audio/transcriptions). Sin STT_API_KEY el agente funciona igual pero
# las notas de voz quedan como "[nota de voz sin transcribir]".
# STT_API_URL=https://api.openai.com/v1
STT_API_KEY=
# STT_MODEL=whisper-1

# --- Gestor de tareas ---
# Elige el proveedor: jira | linear. Solo hacen falta las variables del elegido.
TASK_PROVIDER=linear

# Jira Cloud (si TASK_PROVIDER=jira)
# JIRA_BASE_URL=https://tallerdelpatinete.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=            # id.atlassian.com → Security → API tokens
# JIRA_PROJECT_KEY=SCRUM     # la KEY del proyecto (se ve en la URL del tablero)
# JIRA_ISSUE_TYPE=Task

# Linear (si TASK_PROVIDER=linear)
# Personal API key: Linear → Settings → Security & access → Personal API keys (empieza por lin_api_)
LINEAR_API_KEY=
# Clave del equipo donde crear los issues (p. ej. TDP); Linear → Settings → Teams → tu equipo.
LINEAR_TEAM_KEY=
# LINEAR_API_URL=https://api.linear.app/graphql

# --- Opcional: notificar cada acción del agente a un flujo de N8N (fase 4) ---
N8N_EVENTS_WEBHOOK_URL=

# ─── Evolution API (servicio 'evolution' de este mismo compose) ──────────────
# El agente le habla por la red interna (default http://evolution:8080).
# EVOLUTION_API_URL=http://evolution:8080
# API key de la instancia de Evolution (AUTHENTICATION_API_KEY) — inventa una:
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=tdp-tareas
# BD PROPIA de Evolution en la PostgreSQL gestionada (usuario/BD 'evolution').
# Con la sesión en BD, la instancia sobrevive a la pérdida del host sin re-QR.
EVOLUTION_DATABASE_URL=postgresql://evolution:PASS@HOST.upclouddatabases.com:11569/evolution?sslmode=require
# EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.1
# CONFIG_SESSION_PHONE_CLIENT=TDP
# EVOLUTION_LOG_LEVEL=ERROR,WARN,INFO

# ─── Dominios (los asigna el workflow vía docker_compose_domains) ────────────
AGENT_DOMAIN=agente.tallerdelpatinete.es
EVOLUTION_DOMAIN=evolution.tallerdelpatinete.es
# Esquema de los dominios en Coolify. Detrás de un Cloudflare Tunnel (TLS en el
# edge, el tunnel entra al :80 de Traefik) usa http para que Traefik NO fuerce
# HTTPS ni pida Let's Encrypt (evita el bucle de redirección). Si expones directo
# con Let's Encrypt, déjalo en https (default).
DOMAIN_SCHEME=http

# ─── N8N (OPCIONAL — se activa con COMPOSE_PROFILES=n8n) ─────────────────────
# COMPOSE_PROFILES=n8n
# N8N_DOMAIN=n8n.tallerdelpatinete.es
# N8N_IMAGE=docker.n8n.io/n8nio/n8n:1.76.1
# Clave fija para que las credenciales guardadas sobrevivan (openssl rand -hex 24):
# N8N_ENCRYPTION_KEY=
# BD propia de n8n en la PostgreSQL gestionada:
# N8N_DB_HOST=HOST.upclouddatabases.com
# N8N_DB_PORT=11569
# N8N_DB_NAME=n8n
# N8N_DB_USER=n8n
# N8N_DB_PASSWORD=
# N8N_DB_SSL=true

# ─── Solo desarrollo local (docker compose --profile local-db up) ────────────
POSTGRES_USER=tdp
POSTGRES_PASSWORD=
POSTGRES_DB=tdp_agente
